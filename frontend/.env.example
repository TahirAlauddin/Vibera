# API Configuration
# Backend API base URL (required)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Toast Notification Configuration
# Maximum number of toasts displayed at once (default: 5)
NEXT_PUBLIC_TOAST_LIMIT=5

# Auto-dismiss duration in milliseconds (default: 5000 = 5 seconds)
# Set to 0 to disable auto-dismiss
NEXT_PUBLIC_TOAST_DURATION=5000

# Toast position (Tailwind CSS classes)
# Options: top-0, top-4, top-8, etc. (default: top-4)
NEXT_PUBLIC_TOAST_POSITION_TOP=top-4

# Options: right-0, right-4, right-8, left-0, left-4, etc. (default: right-4)
NEXT_PUBLIC_TOAST_POSITION_RIGHT=right-4

# Maximum width in pixels (default: 420)
NEXT_PUBLIC_TOAST_MAX_WIDTH=420
