# Django Secret Key - CRITICAL: Generate a unique secret key for production
# You can generate one using: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here
# PostgreSQL Database Configuration
# Database name for your Vibera application
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
# Comma-separated list of allowed hosts/domains (e.g., localhost,127.0.0.1,.yourdomain.com)
# In production, replace with your actual domain names
ALLOWED_HOSTS=localhost,.yourdomain.com
