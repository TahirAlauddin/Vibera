# Django Secret Key - CRITICAL: Generate a unique secret key for production
# You can generate one using: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here
# PostgreSQL Database Configuration
# Database name for your Vibera application
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
# Comma-separated list of allowed hosts/domains (e.g., localhost,127.0.0.1,.yourdomain.com)
# In production, replace with your actual domain names
ALLOWED_HOSTS=localhost,.yourdomain.com

# EMAIL CONFIGURATION (for 2FA OTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL= <your-gmail@gmail.com>

# NOTE: For Gmail, you need an App Password (not your regular password)
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
# 4. Use that 16-character password above

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3